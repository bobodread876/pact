# Copy to .env and edit. All optional.

# Non-custodial Lightning via Nostr Wallet Connect (Alby / Coinos / Primal /
# Phoenix / any NWC wallet). Enables /wallet endpoints + paid markets.
PACT_NWC=

# Paid-verification price in sats (0 = free). Requires PACT_NWC to collect.
PACT_VERIFY_PRICE_SATS=0

# Optional bearer token required on all non-health requests.
PACT_TOKEN=
